# ─── SVENSKA DELIKATESSEN — Variables d'environnement ───────────
# Copier ce fichier en .env.local et remplir les valeurs
# NE PAS commiter .env.local sur GitHub !

# Supabase — Récupérer dans Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...    # Clé secrète — JAMAIS dans le front

# Storage — nom du bucket Supabase
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=svenska-media

# Admin — Email autorisé pour se connecter
ADMIN_EMAIL=kieron@svenska-delikatessen.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_FRONT_URL=https://thriving-pony-1275a9.netlify.app
